# shellcheck shell=bash
# 极简版 env.sh —— 日常脚本：sync-intranet / promote / vps-watch / preflight
#
# 用法：
#   cp private/env.sh.minimal.example private/env.sh
#   $EDITOR private/env.sh
#   chmod 600 private/env.sh
#   source private/env.sh

# ─── 两台 VPS（公网 IPv4）──────────────────────────────────
export VPS_IP_HOSTHATCH="x.x.x.x"        # HostHatch，改成你的
export VPS_IP_VULTR="y.y.y.y"            # Vultr，改成你的

# 单台命令默认走哪台（历史兼容字段）
export VPS_IP="$VPS_IP_HOSTHATCH"

# 多机：sync-intranet.sh --all-vps / vps-watch-urls.sh / preflight-multi-vps.sh
export VPS_NODES="hosthatch:${VPS_IP_HOSTHATCH} vultr:${VPS_IP_VULTR}"

export VPS_SSH_USER="root"
export VPS_SSH_KEY=""                       # 定时免密建议填 $HOME/.ssh/id_rsa；留空则手跑时自动试 key
export SUB_PORT_CLASH="25500"
export LOCAL_PROXY="http://127.0.0.1:7890"

vps-fetch-creds() {
  if [[ -n "${VPS_SSH_KEY:-}" ]]; then
    scp -i "$VPS_SSH_KEY" "$VPS_SSH_USER@$VPS_IP:/root/ace-vpn-credentials.txt" "/tmp/ace-vpn-creds-$$.txt"
  else
    scp "$VPS_SSH_USER@$VPS_IP:/root/ace-vpn-credentials.txt" "/tmp/ace-vpn-creds-$$.txt"
  fi
  chmod 600 "/tmp/ace-vpn-creds-$$.txt"
  echo "已从 ${VPS_IP} 保存到 /tmp/ace-vpn-creds-$$.txt（用完 rm）"
  echo "从 Vultr 再拉一份：VPS_IP=${VPS_IP_VULTR} vps-fetch-creds"
}
