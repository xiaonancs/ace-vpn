# shellcheck shell=bash
# 极简版 env.sh —— 只放"日常诊断 / 同步内网规则"需要的几个变量
# 面板账号 / UUID / pbk 等敏感凭据留在 VPS 的 /root/ace-vpn-credentials.txt，本机不保存
#
# 用法：
#   cp private/env.sh.minimal.example private/env.sh
#   $EDITOR private/env.sh      # 改 VPS_IP 那一行
#   chmod 600 private/env.sh
#   source private/env.sh       # 之后直接跑 scripts/sync-intranet.sh 等

export VPS_IP="x.x.x.x"                            # 必填：VPS 公网 IP
export VPS_SSH_USER="root"                          # SSH 登录用户
export VPS_SSH_KEY="$HOME/.ssh/id_ed25519"          # 可选，默认 key 留空即可
export SUB_PORT_CLASH="25500"                       # sub-converter 监听端口
export LOCAL_PROXY="http://127.0.0.1:7890"          # 本机 Clash 监听端口（test-route.sh 用）

# 紧急时从 VPS 拉完整凭据文件到本地（只留本次使用，用完即删）
vps-fetch-creds() {
  scp -i "$VPS_SSH_KEY" "$VPS_SSH_USER@$VPS_IP:/root/ace-vpn-credentials.txt" /tmp/ace-vpn-creds-$$.txt
  chmod 600 "/tmp/ace-vpn-creds-$$.txt"
  echo "保存到 /tmp/ace-vpn-creds-$$.txt（用完 rm 掉）"
}
