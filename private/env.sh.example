# shellcheck shell=bash
# 复制为 env.sh 后填真实值；env.sh 会被 .gitignore 排除。
# 使用：source private/env.sh

# ==== VPS 基础信息 ====
export VPS_PROVIDER="vultr-tokyo"              # 便于区分：vultr / oracle / hostdare / racknerd
export VPS_IP="xxx.xxx.xxx.xxx"
export VPS_SSH_USER="root"
export VPS_SSH_KEY="$HOME/.ssh/id_ed25519_vps"  # 可选，未用 key 登录就留空

# ==== 3x-ui 面板 ====
export PANEL_PORT="41785"                       # 非默认随机端口
export PANEL_PATH="/xxxxxxxxx"                  # 随机 path（带前导 /）
export PANEL_USER="xxxxxxxx"                    # 你改过的用户名，不是 admin
export PANEL_PASS="xxxxxxxxxxxxxxxx"

# ==== 订阅服务（3x-ui 原生 + 我们的 Clash 转换器）====
export SUB_PORT_XUI="2096"                      # 3x-ui 订阅端口
export SUB_PATH_XUI="/sub_xxxxxxx"              # 订阅路径（带前导 /）
export SUB_JSON_PATH_XUI="/json_xxxxxxx"

export SUB_PORT_CLASH="25500"                   # 我们的 sub-converter 监听端口
export SUB_TOKEN="hxn-home-2026q2"              # /clash/<SUB_TOKEN>

# ==== 每个 SubId（面板里的 client）对应一条订阅 URL ====
export SUB_ID_HOME="sub-hxn"                    # 你自己三台设备共用的 subId
export SUB_ID_DAD=""                            # 如有家人，分配
export SUB_ID_MOM=""

# ==== 常用 URL（脚本里 `$URL_CLASH` 直接可用）====
export URL_XUI_SUB_HOME="https://${VPS_IP}:${SUB_PORT_XUI}${SUB_PATH_XUI}/${SUB_ID_HOME}"
export URL_CLASH_HOME="http://${VPS_IP}:${SUB_PORT_CLASH}/clash/${SUB_TOKEN}"

# ==== 可选：公司内网分流 ====
export COMPANY_CIDRS=""                         # 如 "10.128.0.0/16,172.20.0.0/16"
export COMPANY_SFX=""                           # 如 "corp.example.com,internal.example.com"

# ==== 常用小工具 ====
vps-ssh()  { ssh -i "$VPS_SSH_KEY" "${VPS_SSH_USER}@${VPS_IP}" "$@"; }
vps-scp()  { scp -i "$VPS_SSH_KEY" "$@" "${VPS_SSH_USER}@${VPS_IP}:/tmp/"; }
vps-xui()  { vps-ssh -t "x-ui"; }
vps-credentials() { scp -i "$VPS_SSH_KEY" "${VPS_SSH_USER}@${VPS_IP}:/root/ace-vpn-credentials.txt" "$(dirname "$BASH_SOURCE")/credentials.txt"; chmod 600 "$(dirname "$BASH_SOURCE")/credentials.txt"; }
